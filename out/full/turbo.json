{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**"
      ]
    },
    "start:dev": {
      "cache": false,
      "dependsOn": [
        "^build"
      ],
      "persistent": true
    }
  },
  "ui": "tui"
}