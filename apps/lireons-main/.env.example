# Server
LIREONS_MAIN_PORT=4000

# Database (Prisma / Postgres) - required for auth
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lireons_lms?schema=public

# JWT (required for auth)
JWT_SECRET=your-secret-key-change-in-production

# Email (for OTP) - use quotes if password has spaces (e.g. Gmail App Password)
EMAIL_USER=
EMAIL_PASSWORD=

# OTP
OTP_SECRET=your-otp-secret

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000
