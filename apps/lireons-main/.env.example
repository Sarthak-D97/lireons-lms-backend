# Server
LIREONS_MAIN_PORT=4000

# Database (Prisma / Postgres) - required for auth
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lireons_lms?schema=public

# JWT (required for auth)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_ACCESS_SECRET=your-access-secret-key
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key
JWT_REFRESH_EXPIRES_IN=30d

# Email (for OTP) - use quotes if password has spaces (e.g. Gmail App Password)
EMAIL_USER=
EMAIL_PASSWORD=

# OTP
OTP_SECRET=your-otp-secret

# Frontend (for CORS)
FRONTEND_URL=http://localhost:3000

# AWS S3 (optional in local, required in production for uploads)
AWS_S3_REGION=
AWS_S3_BUCKET_NAME=
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
# Optional: set for S3-compatible providers or explicit bucket endpoint
AWS_S3_ENDPOINT=
# Optional: true for MinIO/Spaces-style path URLs (default false)
AWS_S3_FORCE_PATH_STYLE=false
